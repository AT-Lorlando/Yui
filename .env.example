# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
BEARER_TOKEN=yui
SAVE_STORIES=true

# ── LLM ───────────────────────────────────────────────────────────────────────
# Deepseek (recommended) or OpenAI — OPENAI_API_KEY is the field name for compat
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── Philips Hue ───────────────────────────────────────────────────────────────
# Written automatically by: npm run setup:hue
HUE_BRIDGE_IP=
HUE_USERNAME=

# ── Nuki ──────────────────────────────────────────────────────────────────────
# Written automatically by: npm run setup:nuki -- <bridge-ip>
NUKI_HOST=
NUKI_PORT=8080
NUKI_TOKEN=

# ── Spotify ───────────────────────────────────────────────────────────────────
# Create app at: https://developer.spotify.com/dashboard
# Then run: npm run setup:spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:6145/callback
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_SEEDER_DEVICE=Chromecaste

# ── Samsung TV (SmartThings + Wake-on-LAN) ────────────────────────────────────
# Token: https://account.smartthings.com/tokens
# Device ID: curl -H "Authorization: Bearer <token>" https://api.smartthings.com/v1/devices
SMARTTHINGS_TOKEN=
SMARTTHINGS_TV_DEVICE_ID=
SMARTTHINGS_TV_MAC=
SMARTTHINGS_TV_IP=

# ── Google (Calendar + Gmail) ─────────────────────────────────────────────────
# Create OAuth2 credentials at: https://console.cloud.google.com/
# Enable: Google Calendar API + Gmail API (both in the same project)
# Then run: npm run setup:google  → writes GOOGLE_REFRESH_TOKEN (covers both)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Linear ────────────────────────────────────────────────────────────────────
# Settings > API > Personal API keys
LINEAR_API_KEY=

# ── Voice pipeline ────────────────────────────────────────────────────────────
SPEAK_PIPELINE_URL=http://localhost:3001/speak

# XTTS server — used by voice pipeline AND by /order?audio=true for remote TTS
# When a mobile app sends { audio: true } in the /order body, the orchestrator
# calls this server to generate WAV audio and returns it as base64 in the response.
TTS_SERVER_URL=http://localhost:18770/tts
XTTS_SPEAKER=Lilya Stainthorpe
# Stop words — saying any of these during playback immediately halts the assistant
# STOP_WORDS=stop,arrête,attends,tais-toi,silence,pause
# Speaker verification — path to a ~12s WAV of your voice (record with: npm run record-voice)
# SPEAKER_REF_WAV=/path/to/assets/my_voice.wav
# SPEAKER_SIMILARITY_THRESH=0.75
XTTS_SPEED=1.15

# Trigger word — utterances without this word are silently ignored
# Say it anywhere: "Lunix, allume les lumières" or "allume les lumières Lunix"
TRIGGER_WORD=Lunix

# Whisper model — large-v3-turbo recommended for RTX 3090 (fast + high quality)
# Options: tiny | base | small | medium | large-v2 | large-v3 | large-v3-turbo
WHISPER_MODEL=large-v3-turbo
