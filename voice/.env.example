# voice/.env.example — variables lues par yui-voice et yui-tts (sourcé par les wrappers)
# Audio / wake / STT
AUDIO_UDP_PORT=5002
DEBUG_WS_PORT=5051
WAKEWORD_MODEL=hey_jarvis
WAKEWORD_NAME=yui
WAKEWORD_THRESHOLD=0.5
TRIGGER_WORD=jarvis
WHISPER_MODEL=distil-large-v3-fr
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANG=fr
# Pin Whisper sur GPU1 (GPU0 saturé par llama-server + XTTS)
CUDA_VISIBLE_DEVICES=1
SAVE_AUDIO_DEBUG=false
# TTS / XTTS
COQUI_TOS_AGREED=1
XTTS_PORT=18770
XTTS_SPEAKER=Ana Florence
XTTS_SPEAKER_WAV=
TTS_ENGINE=xtts
SPEAK_PORT=3001
LOCAL_IP=10.0.0.101
# Partagé avec l'orchestrateur (duplication assumée)
BEARER_TOKEN=changeme
ORCHESTRATOR_PORT=4000
